# DXP Platform — Environment Configuration
# Copy to .env and adjust values.

# --- PostgreSQL ---
POSTGRES_USER=dxp
POSTGRES_PASSWORD=dxp_local_pass
POSTGRES_DB=dxp

# --- Redis ---
REDIS_PASSWORD=dxp_redis_pass

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://localhost:5025
KEYCLOAK_REALM=dxp

# --- BFF ---
BFF_PORT=5021
CMS_ADAPTER=strapi
STORAGE_PROVIDER=s3

# --- Public URL / Frontend ---
DXP_PUBLIC_BASE_URL=
VITE_DXP_PUBLIC_BASE_URL=
VITE_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Adapter Config (per engagement) ---
STRAPI_URL=http://localhost:5029
STRAPI_API_TOKEN=
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=dxp-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=


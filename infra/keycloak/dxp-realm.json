{
  "realm": "dxp",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "platform-admin",
        "description": "Full platform administration access"
      },
      {
        "name": "portal-admin",
        "description": "Portal-level administration"
      },
      {
        "name": "portal-user",
        "description": "Standard portal user"
      }
    ]
  },
  "clients": [
    {
      "clientId": "dxp-bff",
      "name": "DXP Backend for Frontend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "dxp-bff-secret-local",
      "redirectUris": ["http://localhost:*/*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "protocolMappers": [
        {
          "name": "tenant-id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "dxp-shell",
      "name": "DXP Shell Application",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:4200/*"],
      "webOrigins": ["http://localhost:4200"],
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "tenant-id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin@dxp.local",
      "email": "admin@dxp.local",
      "enabled": true,
      "firstName": "Platform",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["platform-admin"],
      "attributes": {
        "tenant_id": ["platform"]
      }
    },
    {
      "username": "user@acme.local",
      "email": "user@acme.local",
      "enabled": true,
      "firstName": "Acme",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "user",
          "temporary": false
        }
      ],
      "realmRoles": ["portal-user"],
      "attributes": {
        "tenant_id": ["acme"]
      }
    }
  ]
}
